# ??????????????????????????????????????????????????????????????????????????????
# modules/network/main.tf
#
# MO?DULO: Infraestructura de red para Brainmart
# Crea una VPC con 3 capas de subnets (pu?blica, privada, aislada),
# NAT Gateway, Internet Gateway, y VPC Endpoints para servicios AWS.
#
# DISEN?O DE 3 CAPAS:
#   PU?BLICA  ? ALB, NAT Gateway (tienen IP pu?blica)
#   PRIVADA  ? ECS Fargate (acceso a internet via NAT, no tienen IP pu?blica)
#   AISLADA  ? RDS, ElastiCache (SIN acceso a internet en ninguna direccio?n)
#
# Este disen?o implementa "defensa en profundidad":
# Para llegar a la BD, un atacante necesita comprometer:
#   Internet ? WAF/CloudFront ? ALB (subnet pu?blica)
#           ? ECS Fargate (subnet privada)
#           ? RDS (subnet aislada, solo accesible desde privada)
#
# CUMPLIMIENTO:
#   - FDA 21 CFR Part 11: Control de acceso a datos de pacientes
#   - NIST SP 800-53 SC-7: Proteccio?n de li?mites de red
# ??????????????????????????????????????????????????????????????????????????????

terraform {
  required_version = ">= 1.7.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.40"
    }
  }
}

# ??????????????????????????????????????????????????????????????????????????????
# DATA SOURCES
# ??????????????????????????????????????????????????????????????????????????????

# Obtener el ID de la cuenta actual (para construir ARNs y nombres)
data "aws_caller_identity" "current" {}

# Obtener la regio?n actual
data "aws_region" "current" {}

# ??????????????????????????????????????????????????????????????????????????????
# VPC PRINCIPAL
# ??????????????????????????????????????????????????????????????????????????????

resource "aws_vpc" "main" {
  cidr_block = var.vpc_cidr

  # DNS habilitado: necesario para VPC Endpoints y Service Discovery (Cloud Map)
  enable_dns_hostnames = var.enable_dns_hostnames
  enable_dns_support   = var.enable_dns_support

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-vpc"
  })
}

# ??????????????????????????????????????????????????????????????????????????????
# INTERNET GATEWAY
# Permite que las subnets pu?blicas (ALB, NAT) se comuniquen con internet
# Las subnets privadas y aisladas NO tienen ruta directa al IGW
# ??????????????????????????????????????????????????????????????????????????????

resource "aws_internet_gateway" "main" {
  vpc_id = aws_vpc.main.id

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-igw"
  })
}

# ??????????????????????????????????????????????????????????????????????????????
# SUBNETS PU?BLICAS
# Solo para: ALB (Application Load Balancer) y NAT Gateway
# Los microservicios y BD NUNCA se despliegan aqui?
# ??????????????????????????????????????????????????????????????????????????????

resource "aws_subnet" "public" {
  count = length(var.public_subnet_cidrs)

  vpc_id            = aws_vpc.main.id
  cidr_block        = var.public_subnet_cidrs[count.index]
  availability_zone = var.availability_zones[count.index]

  # Las instancias en subnets pu?blicas NUNCA deben tener IP pu?blica por defecto
  # El ALB tiene su propia IP pu?blica asignada expli?citamente
  map_public_ip_on_launch = false

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-public-subnet-${count.index + 1}"
    Tier = "public"
    # Tags necesarios para que AWS Load Balancer Controller (EKS) o ALB
    # descubra automa?ticamente las subnets correctas
    "kubernetes.io/role/elb" = "1"
  })
}

# ??????????????????????????????????????????????????????????????????????????????
# SUBNETS PRIVADAS
# Para: ECS Fargate (microservicios .NET 8)
# Tienen acceso SALIENTE a internet via NAT Gateway (para pull de ima?genes ECR)
# NO tienen acceso ENTRANTE desde internet
# ??????????????????????????????????????????????????????????????????????????????

resource "aws_subnet" "private" {
  count = length(var.private_subnet_cidrs)

  vpc_id            = aws_vpc.main.id
  cidr_block        = var.private_subnet_cidrs[count.index]
  availability_zone = var.availability_zones[count.index]

  map_public_ip_on_launch = false

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-private-subnet-${count.index + 1}"
    Tier = "private"
    "kubernetes.io/role/internal-elb" = "1"
  })
}

# ??????????????????????????????????????????????????????????????????????????????
# SUBNETS AISLADAS
# Para: RDS PostgreSQL, ElastiCache
# SIN ningu?n acceso a internet (ni entrante ni saliente)
# Solo accesibles desde las subnets privadas via Security Groups
# ??????????????????????????????????????????????????????????????????????????????

resource "aws_subnet" "isolated" {
  count = length(var.isolated_subnet_cidrs)

  vpc_id            = aws_vpc.main.id
  cidr_block        = var.isolated_subnet_cidrs[count.index]
  availability_zone = var.availability_zones[count.index]

  map_public_ip_on_launch = false

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-isolated-subnet-${count.index + 1}"
    Tier = "isolated"
  })
}

# ??????????????????????????????????????????????????????????????????????????????
# NAT GATEWAY + ELASTIC IPs
# Permite que las subnets privadas accedan a internet (saliente u?nicamente)
# Necesario para: pull de ima?genes ECR, actualizaciones de OS, llamadas a APIs externas
#
# single_nat_gateway = true en dev (una AZ, ahorro de costos)
# single_nat_gateway = false en prod (una por AZ, alta disponibilidad)
# ??????????????????????????????????????????????????????????????????????????????

# Elastic IPs para los NAT Gateways
resource "aws_eip" "nat" {
  # Si single_nat_gateway = true ? 1 EIP; si false ? una por AZ
  count  = var.single_nat_gateway ? 1 : length(var.availability_zones)
  domain = "vpc"

  # La EIP depende del IGW para existir
  depends_on = [aws_internet_gateway.main]

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-nat-eip-${count.index + 1}"
  })
}

resource "aws_nat_gateway" "main" {
  count = var.single_nat_gateway ? 1 : length(var.availability_zones)

  allocation_id = aws_eip.nat[count.index].id

  # El NAT Gateway se ubica en la subnet PU?BLICA
  # pero permite que subnets PRIVADAS salgan a internet
  subnet_id = aws_subnet.public[count.index].id

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-nat-gw-${count.index + 1}"
  })

  depends_on = [aws_internet_gateway.main]
}

# ??????????????????????????????????????????????????????????????????????????????
# ROUTE TABLES
# Definen co?mo se enruta el tra?fico en cada tipo de subnet
# ??????????????????????????????????????????????????????????????????????????????

# Route table PU?BLICA: tra?fico 0.0.0.0/0 ? Internet Gateway
resource "aws_route_table" "public" {
  vpc_id = aws_vpc.main.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.main.id
  }

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-public-rt"
  })
}

resource "aws_route_table_association" "public" {
  count          = length(aws_subnet.public)
  subnet_id      = aws_subnet.public[count.index].id
  route_table_id = aws_route_table.public.id
}

# Route table PRIVADA: tra?fico 0.0.0.0/0 ? NAT Gateway (solo salida)
# Si single_nat_gateway = true: todas las subnets privadas usan el mismo NAT
# Si single_nat_gateway = false: cada subnet usa el NAT de su AZ (HA)
resource "aws_route_table" "private" {
  count  = var.single_nat_gateway ? 1 : length(var.availability_zones)
  vpc_id = aws_vpc.main.id

  route {
    cidr_block     = "0.0.0.0/0"
    nat_gateway_id = aws_nat_gateway.main[count.index].id
  }

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-private-rt-${count.index + 1}"
  })
}

resource "aws_route_table_association" "private" {
  count     = length(aws_subnet.private)
  subnet_id = aws_subnet.private[count.index].id
  route_table_id = var.single_nat_gateway ? (
    aws_route_table.private[0].id
  ) : (
    aws_route_table.private[count.index].id
  )
}

# Route table AISLADA: SIN ruta a internet
# No hay route a 0.0.0.0/0 ? tra?fico fuera de la VPC es bloqueado
resource "aws_route_table" "isolated" {
  vpc_id = aws_vpc.main.id

  # Sin rutas adicionales: solo tra?fico local de la VPC (0.0.0.0/0 no existe)

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-isolated-rt"
  })
}

resource "aws_route_table_association" "isolated" {
  count          = length(aws_subnet.isolated)
  subnet_id      = aws_subnet.isolated[count.index].id
  route_table_id = aws_route_table.isolated.id
}

# CKV2_AWS_12: Restrict the default security group traffic
resource "aws_default_security_group" "default" {
  vpc_id = aws_vpc.main.id
  tags   = merge(var.tags, { Name = "${var.name_prefix}-default-sg-restricted" })
}

# ??????????????????????????????????????????????????????????????????????????????
# SECURITY GROUPS
# Define reglas de firewall a nivel de recurso (complementa las NACLs de subnet)
# ??????????????????????????????????????????????????????????????????????????????

# Security Group para el ALB (Application Load Balancer)
# Solo acepta HTTPS entrante desde internet; rechaza HTTP
resource "aws_security_group" "alb" {
  name        = "${var.name_prefix}-alb-sg"
  description = "Security Group for ALB - HTTPS only from internet"
  vpc_id      = aws_vpc.main.id

  # ENTRADA: solo HTTPS (443) desde cualquier IP
  # HTTP (80) no esta? permitido: redirigir a HTTPS debe ser manejado por el ALB listener
  ingress {
    description = "HTTPS from internet"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  # SALIDA: hacia los microservicios en subnets privadas
  # Solo al puerto de la aplicacio?n .NET (8080)
  egress {
    description = "To ECS microservices in private subnets"
    from_port   = 8080
    to_port     = 8080
    protocol    = "tcp"
    cidr_blocks = var.private_subnet_cidrs
  }

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-alb-sg"
  })

  lifecycle {
    # description is immutable in AWS (cannot be changed in-place).
    # Ignoring it prevents destroy+recreate when description text changes,
    # which would cause DependencyViolation (VPC endpoints / ENIs attached)
    # and InvalidGroup.Duplicate (create_before_destroy + same name).
    ignore_changes = [description]
  }
}

# Security Group para ECS Fargate (microservicios .NET 8)
resource "aws_security_group" "ecs" {
  name        = "${var.name_prefix}-ecs-sg"
  description = "Security Group for ECS Fargate tasks - Brainmart"
  vpc_id      = aws_vpc.main.id

  # ENTRADA: solo desde el ALB en el puerto de la aplicacio?n
  ingress {
        description = "From ALB to .NET application on port 8080"
    from_port       = 8080
    to_port         = 8080
    protocol        = "tcp"
    security_groups = [aws_security_group.alb.id]  # Solo desde el SG del ALB
  }

  # SALIDA: hacia RDS (PostgreSQL), Secrets Manager (via VPC Endpoint), S3 y ECR
  egress {
    description = "To RDS PostgreSQL in isolated subnets"
    from_port   = 5432
    to_port     = 5432
    protocol    = "tcp"
    cidr_blocks = var.isolated_subnet_cidrs
  }

  egress {
    description = "HTTPS to VPC Endpoints and NAT (ECR, Secrets Manager, etc.)"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]  # Necesario para NAT ? internet (ECR, actualizaciones)
  }

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-ecs-sg"
  })

  lifecycle {
    ignore_changes = [description]
  }
}

# Security Group para RDS PostgreSQL
resource "aws_security_group" "rds" {
  name        = "${var.name_prefix}-rds-sg"
  description = "Security Group for RDS PostgreSQL - ECS access only"
  vpc_id      = aws_vpc.main.id

  # ENTRADA: solo desde los microservicios ECS en el puerto PostgreSQL
  # CRI?TICO: 0.0.0.0/0 en el puerto 5432 esta? prohibido por SCP de Capa 0
  ingress {
        description = "PostgreSQL from ECS microservices"
    from_port       = 5432
    to_port         = 5432
    protocol        = "tcp"
    security_groups = [aws_security_group.ecs.id]  # Solo desde el SG de ECS
  }

  # SALIDA: ninguna (la BD solo responde a conexiones entrantes)
  egress {
    description = "No outbound from RDS"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["127.0.0.1/32"]  # Solo loopback = efectivamente sin salida
  }

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-rds-sg"
  })

  lifecycle {
    ignore_changes = [description]
  }
}

# Security Group para VPC Endpoints
resource "aws_security_group" "vpc_endpoints" {
  name        = "${var.name_prefix}-vpc-endpoints-sg"
  description = "Security Group for VPC Endpoints - Brainmart"
  vpc_id      = aws_vpc.main.id

  # Los VPC Endpoints responden en HTTPS desde recursos dentro de la VPC
  ingress {
    description = "HTTPS from resources inside the VPC"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = [var.vpc_cidr]  # Solo desde dentro de la VPC
  }

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-vpc-endpoints-sg"
  })

  lifecycle {
    # description is immutable; ignore_changes prevents destroy+recreate.
    # vpc_endpoints SG cannot be deleted while Interface Endpoints reference it
    # (DependencyViolation) - so we must never trigger replacement.
    ignore_changes = [description]
  }
}

# ??????????????????????????????????????????????????????????????????????????????
# VPC ENDPOINTS
# Tra?fico a servicios AWS sin salir a internet:
#   - Ma?s seguro: no pasa por NAT Gateway ni internet pu?blico
#   - Ma?s barato: menos tra?fico de NAT
#   - Ma?s ra?pido: tra?fico en la red interna de AWS
#
# Interface Endpoints (cobran por hora + por GB):
#   - Secrets Manager: para que ECS lea credenciales
#   - ECR API + Docker: para pull de ima?genes sin internet
#   - CloudWatch Logs: para envi?o de logs sin internet
#
# Gateway Endpoints (GRATUITOS):
#   - S3: para acceso a buckets sin internet
#   - DynamoDB: para state lock (si aplica)
# ??????????????????????????????????????????????????????????????????????????????

# ?? Gateway Endpoint S3 (gratuito) ??
resource "aws_vpc_endpoint" "s3" {
  count = var.enable_vpc_endpoints && var.vpc_endpoints.s3 ? 1 : 0

  vpc_id            = aws_vpc.main.id
  service_name      = "com.amazonaws.${data.aws_region.current.name}.s3"
  vpc_endpoint_type = "Gateway"

  # Asociar a todas las route tables (pu?blica, privada, aislada)
  route_table_ids = concat(
    [aws_route_table.public.id],
    aws_route_table.private[*].id,
    [aws_route_table.isolated.id]
  )

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-s3-endpoint"
  })
}

# ?? Gateway Endpoint DynamoDB (gratuito) ??
resource "aws_vpc_endpoint" "dynamodb" {
  count = var.enable_vpc_endpoints && lookup(var.vpc_endpoints, "dynamodb", false) ? 1 : 0

  vpc_id            = aws_vpc.main.id
  service_name      = "com.amazonaws.${data.aws_region.current.name}.dynamodb"
  vpc_endpoint_type = "Gateway"

  route_table_ids = concat(
    [aws_route_table.public.id],
    aws_route_table.private[*].id
  )

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-dynamodb-endpoint"
  })
}

# ?? Interface Endpoint: Secrets Manager ??
resource "aws_vpc_endpoint" "secrets_manager" {
  count = var.enable_vpc_endpoints && var.vpc_endpoints.secrets_manager ? 1 : 0

  vpc_id              = aws_vpc.main.id
  service_name        = "com.amazonaws.${data.aws_region.current.name}.secretsmanager"
  vpc_endpoint_type   = "Interface"
  private_dns_enabled = true  # Los hostnames de Secrets Manager resuelven al endpoint privado

  subnet_ids         = aws_subnet.private[*].id
  security_group_ids = [aws_security_group.vpc_endpoints.id]

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-secretsmanager-endpoint"
  })
}

# ?? Interface Endpoint: ECR API ??
resource "aws_vpc_endpoint" "ecr_api" {
  count = var.enable_vpc_endpoints && var.vpc_endpoints.ecr_api ? 1 : 0

  vpc_id              = aws_vpc.main.id
  service_name        = "com.amazonaws.${data.aws_region.current.name}.ecr.api"
  vpc_endpoint_type   = "Interface"
  private_dns_enabled = true

  subnet_ids         = aws_subnet.private[*].id
  security_group_ids = [aws_security_group.vpc_endpoints.id]

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-ecr-api-endpoint"
  })
}

# ?? Interface Endpoint: ECR Docker (para pull de ima?genes) ??
resource "aws_vpc_endpoint" "ecr_dkr" {
  count = var.enable_vpc_endpoints && var.vpc_endpoints.ecr_dkr ? 1 : 0

  vpc_id              = aws_vpc.main.id
  service_name        = "com.amazonaws.${data.aws_region.current.name}.ecr.dkr"
  vpc_endpoint_type   = "Interface"
  private_dns_enabled = true

  subnet_ids         = aws_subnet.private[*].id
  security_group_ids = [aws_security_group.vpc_endpoints.id]

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-ecr-dkr-endpoint"
  })
}

# ?? Interface Endpoint: CloudWatch Logs ??
resource "aws_vpc_endpoint" "cloudwatch_logs" {
  count = var.enable_vpc_endpoints && var.vpc_endpoints.logs ? 1 : 0

  vpc_id              = aws_vpc.main.id
  service_name        = "com.amazonaws.${data.aws_region.current.name}.logs"
  vpc_endpoint_type   = "Interface"
  private_dns_enabled = true

  subnet_ids         = aws_subnet.private[*].id
  security_group_ids = [aws_security_group.vpc_endpoints.id]

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-logs-endpoint"
  })
}

# ??????????????????????????????????????????????????????????????????????????????
# VPC FLOW LOGS
# Registra todo el tra?fico IP en la VPC para auditori?a y ana?lisis forense.
# Obligatorio: Config Rule de Capa 0 verifica que este? habilitado.
# GDPR: permite detectar intentos de exfiltracio?n de datos de pacientes.
# ??????????????????????????????????????????????????????????????????????????????

resource "aws_cloudwatch_log_group" "vpc_flow_logs" {
  count = var.enable_flow_logs ? 1 : 0

  name              = "/aws/vpc/flow-logs/${var.name_prefix}"
  retention_in_days = var.flow_logs_retention_in_days
  # kms_key_id only when explicitly set: passing null crashes CreateLogGroup in
  # provider ~5.x when no CMK exists yet (InvalidParameterException).
  kms_key_id = var.kms_key_id != "" ? var.kms_key_id : null

  tags = var.tags

  lifecycle {
    # Ignore changes to kms_key_id so that adding encryption later does not
    # force a destroy/recreate of the log group (which would delete log data).
    ignore_changes = [kms_key_id]
  }
}

resource "aws_iam_role" "vpc_flow_logs" {
  count = var.enable_flow_logs ? 1 : 0

  name = "${var.name_prefix}-vpc-flow-logs-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect = "Allow"
      Principal = {
        Service = "vpc-flow-logs.amazonaws.com"
      }
      Action = "sts:AssumeRole"
    }]
  })

  tags = var.tags
}

resource "aws_iam_role_policy" "vpc_flow_logs" {
  count = var.enable_flow_logs ? 1 : 0

  name = "${var.name_prefix}-vpc-flow-logs-policy"
  role = aws_iam_role.vpc_flow_logs[0].id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect = "Allow"
      Action = [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents",
        "logs:DescribeLogGroups",
        "logs:DescribeLogStreams"
      ]
      Resource = [
        "arn:aws:logs:*:*:log-group:/aws/vpc/flow-logs/${var.name_prefix}:*",
        "arn:aws:logs:*:*:log-group:/aws/vpc/flow-logs/${var.name_prefix}"
      ]
    }]
  })
}

resource "aws_flow_log" "main" {
  count = var.enable_flow_logs ? 1 : 0

  vpc_id               = aws_vpc.main.id
  traffic_type         = "ALL"
  log_destination_type = "cloud-watch-logs"
  log_destination      = aws_cloudwatch_log_group.vpc_flow_logs[0].arn
  iam_role_arn         = aws_iam_role.vpc_flow_logs[0].arn
  max_aggregation_interval = 600

  # Explicit depends_on: IAM role policy must be fully attached and the log
  # group must exist before AWS accepts the CreateFlowLogs API call.
  depends_on = [
    aws_iam_role_policy.vpc_flow_logs,
    aws_cloudwatch_log_group.vpc_flow_logs,
  ]

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-flow-logs"
  })
}

# ??????????????????????????????????????????????????????????????????????????????
# DB SUBNET GROUP
# Agrupa las subnets aisladas para que RDS pueda ser Multi-AZ
# (RDS necesita subnets en al menos 2 AZs para el failover automa?tico)
# ??????????????????????????????????????????????????????????????????????????????

resource "aws_db_subnet_group" "main" {
  name        = "${var.name_prefix}-db-subnet-group"
  description = "Subnet group para RDS PostgreSQL en subnets aisladas de ${var.name_prefix}"
  subnet_ids  = aws_subnet.isolated[*].id

  tags = merge(var.tags, {
    Name = "${var.name_prefix}-db-subnet-group"
  })
}
