# ??????????????????????????????????????????????????????????????????????????????
# modules/secrets/main.tf
#
# MO?DULO: AWS Secrets Manager para todos los secretos de Brainmart
#
# GESTIONA:
#   1. JWT Signing Key (rotacio?n automa?tica cada 30 di?as)
#   2. API Keys de terceros (integracio?n con CROs, laboratorios)
#   3. Configuracio?n de rotacio?n con Lambda
#
# NOTA: Las credenciales de RDS se crean en el mo?dulo database/main.tf
# porque dependen del endpoint de la BD que se conoce solo despue?s de crearla.
# ??????????????????????????????????????????????????????????????????????????????

terraform {
  required_version = ">= 1.7.0"
  required_providers {
    aws    = { source = "hashicorp/aws"; version = "~> 5.40" }
    random = { source = "hashicorp/random"; version = "~> 3.6" }
  }
}

data "aws_caller_identity" "current" {}
data "aws_region" "current" {}

# ??????????????????????????????????????????????????????????????????????????????
# KMS CMK para secretos (separada de la de RDS)
# ??????????????????????????????????????????????????????????????????????????????

resource "aws_kms_key" "secrets" {
  description             = "KMS CMK para Secrets Manager de ${var.name_prefix}"
  deletion_window_in_days = 30
  enable_key_rotation     = true  # Rotacio?n anual obligatoria (SCP Capa 0)

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "EnableIAM"
        Effect = "Allow"
        Principal = { AWS = "arn:aws:iam::${data.aws_caller_identity.current.account_id}:root" }
        Action   = "kms:*"
        Resource = "*"
      },
      {
        Sid    = "AllowSecretsManager"
        Effect = "Allow"
        Principal = { Service = "secretsmanager.amazonaws.com" }
        Action = ["kms:Decrypt", "kms:GenerateDataKey", "kms:CreateGrant"]
        Resource = "*"
      }
    ]
  })

  tags = merge(var.tags, { Name = "${var.name_prefix}-secrets-kms-key" })
}

resource "aws_kms_alias" "secrets" {
  name          = "alias/${var.name_prefix}-secrets"
  target_key_id = aws_kms_key.secrets.key_id
}

# ??????????????????????????????????????????????????????????????????????????????
# JWT SIGNING KEY
# Clave asime?trica RSA-2048 para firmar y verificar JWT tokens
# Rotacio?n: cada 30 di?as (los tokens activos siguen va?lidos hasta su expiracio?n)
# ??????????????????????????????????????????????????????????????????????????????

resource "random_password" "jwt_signing_key" {
  length  = 64
  special = false  # Solo alfanume?rico para evitar problemas de escapado en JWT
}

resource "aws_secretsmanager_secret" "jwt_signing_key" {
  name        = "${var.name_prefix}/jwt/signing-key"
  description = "Clave de firma para JWT tokens de la aplicacio?n Brainmart"
  kms_key_id  = aws_kms_key.secrets.id

  # Rotacio?n automa?tica cada 30 di?as
  # La Lambda de rotacio?n genera una nueva clave y la versio?n anterior
  # permanece disponible para verificar tokens existentes durante el peri?odo de gracia
  rotation_rules {
    automatically_after_days = 30
  }

  recovery_window_in_days = 30

  tags = merge(var.tags, {
    Name    = "${var.name_prefix}/jwt/signing-key"
    Purpose = "JWTSigning"
    RotationDays = "30"
  })
}

resource "aws_secretsmanager_secret_version" "jwt_signing_key" {
  secret_id     = aws_secretsmanager_secret.jwt_signing_key.id
  secret_string = jsonencode({
    signing_key        = random_password.jwt_signing_key.result
    algorithm          = "HS256"
    expiration_minutes = 60
    refresh_days       = 7
    created_at         = timestamp()
  })

  lifecycle {
    ignore_changes = [secret_string]  # La rotacio?n automa?tica actualizara? este valor
  }
}

# ??????????????????????????????????????????????????????????????????????????????
# API KEYS DE TERCEROS
# Claves para integraciones con CROs, laboratorios, etc.
# ??????????????????????????????????????????????????????????????????????????????

resource "aws_secretsmanager_secret" "third_party_apis" {
  for_each = var.third_party_api_keys

  name        = "${var.name_prefix}/integrations/${each.key}"
  description = "API key para la integracio?n con ${each.key}"
  kms_key_id  = aws_kms_key.secrets.id

  # Rotacio?n manual (cada proveedor tiene su propio proceso de rotacio?n)
  recovery_window_in_days = 30

  tags = merge(var.tags, {
    Name        = "${var.name_prefix}/integrations/${each.key}"
    Integration = each.key
    Purpose     = "ThirdPartyAPI"
  })
}

resource "aws_secretsmanager_secret_version" "third_party_apis" {
  for_each = var.third_party_api_keys

  secret_id     = aws_secretsmanager_secret.third_party_apis[each.key].id
  secret_string = jsonencode(each.value)
}

# ??????????????????????????????????????????????????????????????????????????????
# LAMBDA DE ROTACIO?N DE JWT
# Se ejecuta automa?ticamente cada 30 di?as para rotar la clave de firma
# ??????????????????????????????????????????????????????????????????????????????

resource "aws_iam_role" "rotation_lambda" {
  name = "${var.name_prefix}-secrets-rotation-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect    = "Allow"
      Principal = { Service = "lambda.amazonaws.com" }
      Action    = "sts:AssumeRole"
    }]
  })

  tags = var.tags
}

resource "aws_iam_role_policy" "rotation_lambda" {
  name = "${var.name_prefix}-rotation-policy"
  role = aws_iam_role.rotation_lambda.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "SecretsManagerRotation"
        Effect = "Allow"
        Action = [
          "secretsmanager:DescribeSecret",
          "secretsmanager:GetSecretValue",
          "secretsmanager:PutSecretValue",
          "secretsmanager:UpdateSecretVersionStage"
        ]
        Resource = "arn:aws:secretsmanager:${data.aws_region.current.name}:${data.aws_caller_identity.current.account_id}:secret:${var.name_prefix}/*"
      },
      {
        Sid    = "CloudWatchLogs"
        Effect = "Allow"
        Action = ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:PutLogEvents"]
        Resource = "arn:aws:logs:*:*:*"
      },
      {
        Sid    = "KMSAccess"
        Effect = "Allow"
        Action = ["kms:Decrypt", "kms:GenerateDataKey"]
        Resource = aws_kms_key.secrets.arn
      }
    ]
  })
}

resource "aws_lambda_function" "rotation" {
  function_name = "${var.name_prefix}-jwt-key-rotation"
  description   = "Rota automa?ticamente la clave de firma JWT cada 30 di?as"
  role          = aws_iam_role.rotation_lambda.arn
  runtime       = "python3.12"
  handler       = "index.handler"
  timeout       = 30

  filename         = "${path.module}/lambda/rotation.zip"
  source_code_hash = filebase64sha256("${path.module}/lambda/rotation.zip")

  environment {
    variables = {
      SECRET_NAME = aws_secretsmanager_secret.jwt_signing_key.name
      ENVIRONMENT = var.environment
    }
  }

  tags = var.tags
}

# Permitir que Secrets Manager invoque la Lambda de rotacio?n
resource "aws_lambda_permission" "secrets_manager" {
  statement_id  = "AllowSecretsManagerInvoke"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.rotation.function_name
  principal     = "secretsmanager.amazonaws.com"
  source_arn    = aws_secretsmanager_secret.jwt_signing_key.arn
}

# Asociar la Lambda de rotacio?n al secreto
resource "aws_secretsmanager_secret_rotation" "jwt_signing_key" {
  secret_id           = aws_secretsmanager_secret.jwt_signing_key.id
  rotation_lambda_arn = aws_lambda_function.rotation.arn

  rotation_rules {
    automatically_after_days = 30
  }
}
