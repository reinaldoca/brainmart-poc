# ??????????????????????????????????????????????????????????????????????????????
# environments/prod/network/terragrunt.hcl
# PROD: CIDR 10.30.0.0/16, 3 AZs, NAT por AZ (HA completa)
# ??????????????????????????????????????????????????????????????????????????????

include "root" {
  path   = find_in_parent_folders("root.hcl")
  expose = true
}

terraform {
  source = "../../../../modules//network"
}

inputs = {
  environment        = "prod"
  name_prefix        = "brainmart-prod"
  vpc_cidr           = "10.30.0.0/16"

  # 3 AZs en produccio?n para ma?xima resiliencia
  availability_zones = ["us-east-1a", "us-east-1b", "us-east-1c"]

  public_subnet_cidrs = [
    "10.30.0.0/24", "10.30.1.0/24", "10.30.2.0/24"
  ]
  private_subnet_cidrs = [
    "10.30.10.0/24", "10.30.11.0/24", "10.30.12.0/24"
  ]
  isolated_subnet_cidrs = [
    "10.30.20.0/24", "10.30.21.0/24", "10.30.22.0/24"
  ]

  # PROD: un NAT Gateway por AZ (si una AZ cae, las otras siguen funcionando)
  single_nat_gateway = false

  enable_vpc_endpoints        = true
  enable_flow_logs            = true
  # 7 an?os = FDA 21 CFR Part 11 retencio?n
  flow_logs_retention_in_days = 2555

  vpc_endpoints = {
    secrets_manager = true
    ecr_api         = true
    ecr_dkr         = true
    logs            = true
    s3              = true
  }

  tags = { Module = "network", CriticalityLevel = "critical" }
}
