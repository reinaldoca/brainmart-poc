# ??????????????????????????????????????????????????????????????????????????????
# environments/staging/network/terragrunt.hcl
# CIDR: 10.20.0.0/16 (staging), NAT u?nico, 2 AZs
# ??????????????????????????????????????????????????????????????????????????????

include "root" {
  path   = find_in_parent_folders("root.hcl")
  expose = true
}

terraform {
  source = "../../../modules//network"
}

inputs = {
  environment        = "staging"
  name_prefix        = "brainmart-staging"
  vpc_cidr           = "10.20.0.0/16"
  availability_zones = ["us-east-1a", "us-east-1b"]

  public_subnet_cidrs   = ["10.20.0.0/24", "10.20.1.0/24"]
  private_subnet_cidrs  = ["10.20.10.0/24", "10.20.11.0/24"]
  isolated_subnet_cidrs = ["10.20.20.0/24", "10.20.21.0/24"]

  single_nat_gateway          = true
  enable_vpc_endpoints        = true
  enable_flow_logs            = true
  flow_logs_retention_in_days = 365

  vpc_endpoints = {
    secrets_manager = true
    ecr_api         = true
    ecr_dkr         = true
    logs            = true
    s3              = true
  }

  tags = { Module = "network", CriticalityLevel = "medium" }
}
