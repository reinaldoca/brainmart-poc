# infrastructure/environments/dev/storage/terragrunt.hcl
# ??????????????????????????????????????????????????????????????????????????????

include "root" {
  path   = find_in_parent_folders("root.hcl")
  expose = true
}

terraform {
  source = "../../../modules//storage"
}

dependency "database" {
  config_path = "../database"
  mock_outputs_merge_strategy_with_state  = "shallow"
  mock_outputs_allowed_terraform_commands = ["validate", "plan", "init", "apply"]
  mock_outputs = {
    kms_key_arn             = "arn:aws:kms:us-east-1:222222222222:key/00000000-0000-0000-0000-000000000000"
    audit_export_lambda_arn = "arn:aws:lambda:us-east-1:222222222222:function:brainmart-dev-audit-log-export"
  }
}

inputs = {
  environment                  = "dev"
  name_prefix                  = "brainmart-dev"
  kms_key_arn                  = dependency.database.outputs.kms_key_arn
  audit_export_lambda_role_arn = "arn:aws:iam::222222222222:role/brainmart-dev-audit-export-lambda-role"

  # Dominio: en dev se usa subdomain
  domain_names        = ["app-dev.brainmart.health"]
  acm_certificate_arn = "arn:aws:acm:us-east-1:222222222222:certificate/00000000-0000-0000-0000-000000000000"

  tags = {
    Module           = "storage"
    CriticalityLevel = "low"
  }
}
