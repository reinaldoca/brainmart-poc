# ──────────────────────────────────────────────────────────────────────────────
# .env.example — Variables de entorno necesarias para desplegar Brainmart
# Copiar a .env y completar los valores reales
# NUNCA commitear el archivo .env al repositorio
# ──────────────────────────────────────────────────────────────────────────────

# ── IDs de cuentas AWS ──────────────────────────────────────────────────────
AWS_MASTER_ACCOUNT_ID="381492097033"
AWS_SHARED_SERVICES_ACCOUNT_ID="111111111111"
AWS_DEV_ACCOUNT_ID="381492097033"
AWS_STAGING_ACCOUNT_ID="381492097033"
AWS_PROD_ACCOUNT_ID="444444444444"

# ── Organización AWS ─────────────────────────────────────────────────────────
AWS_ORG_ID="o-xxxxxxxxxxxx"
AWS_ROOT_OU_ID="r-xxxx"

# ── S3 Backend de Terraform ──────────────────────────────────────────────────
TF_STATE_BUCKET_PREFIX="brainmart-tfstate"

# ── SNS para alertas ─────────────────────────────────────────────────────────
SNS_ALERT_TOPIC_ARN="arn:aws:sns:us-east-1:000000000000:brainmart-org-alerts"
AUDIT_BUCKET_NAME="brainmart-audit-logs-000000000000"

# ── Route 53 ────────────────────────────────────────────────────────────────
ROUTE53_HOSTED_ZONE_ID="XXXXXXXXXXXXXXXXXXXX"

# ── Integraciones CI/CD ──────────────────────────────────────────────────────
SONAR_TOKEN="squ_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SONAR_HOST_URL="https://sonarcloud.io"
SNYK_TOKEN="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
SLACK_BOT_TOKEN="xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx"
SLACK_DEPLOY_CHANNEL="C0XXXXXXXXX"
